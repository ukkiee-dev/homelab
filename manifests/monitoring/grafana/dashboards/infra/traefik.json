{
  "uid": "infra-traefik",
  "title": "Traefik",
  "tags": ["traefik", "ingress", "infra"],
  "timezone": "Asia/Seoul",
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "entrypoint",
        "label": "Entrypoint",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "query": {
          "query": "label_values(traefik_entrypoint_requests_total, entrypoint)",
          "refId": "StandardVariableQuery"
        },
        "definition": "label_values(traefik_entrypoint_requests_total, entrypoint)",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "query": {
          "query": "label_values(traefik_service_requests_total{job=\"kubernetes-pods\"}, service)",
          "refId": "StandardVariableQuery"
        },
        "definition": "label_values(traefik_service_requests_total{job=\"kubernetes-pods\"}, service)",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Open Connections",
      "description": "Total active TCP connections across all entrypoints. Sourced from traefik_open_connections.",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(traefik_open_connections{job=\"kubernetes-pods\", entrypoint=~\"$entrypoint\"})",
          "legendFormat": "connections",
          "datasource": {"type": "prometheus", "uid": "victoriametrics"}
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 500},
              {"color": "red", "value": 2000}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Config Reload Success",
      "description": "1 = last config reload succeeded, 0 = failed. Sourced from traefik_config_last_reload_success.",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "refId": "A",
          "expr": "min(traefik_config_last_reload_success{job=\"kubernetes-pods\"})",
          "legendFormat": "reload",
          "datasource": {"type": "prometheus", "uid": "victoriametrics"}
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "unit": "none",
          "mappings": [
            {"type": "value", "options": {"0": {"text": "FAIL", "color": "red"}, "1": {"text": "OK", "color": "green"}}}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "TLS Cert Days Until Expiry",
      "description": "Days remaining on the soonest-expiring TLS cert. Red < 14d, yellow < 30d, green otherwise. Sourced from traefik_tls_certs_not_after.",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "refId": "A",
          "expr": "(min(traefik_tls_certs_not_after{job=\"kubernetes-pods\"}) - time()) / 86400",
          "legendFormat": "days remaining",
          "datasource": {"type": "prometheus", "uid": "victoriametrics"}
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "unit": "d",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 14},
              {"color": "green", "value": 30}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request Rate by Entrypoint",
      "description": "Requests per second on each entrypoint. Stacked view shows total ingress throughput.",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(entrypoint) (rate(traefik_entrypoint_requests_total{job=\"kubernetes-pods\", entrypoint=~\"$entrypoint\"}[5m]))",
          "legendFormat": "{{entrypoint}}",
          "datasource": {"type": "prometheus", "uid": "victoriametrics"}
        }
      ],
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 30,
            "stacking": {"mode": "normal", "group": "A"},
            "showPoints": "never",
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "5xx Error Rate by Entrypoint",
      "description": "Server-side error rate. Any non-zero sustained value indicates backend failures surfaced by Traefik.",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(entrypoint) (rate(traefik_entrypoint_requests_total{job=\"kubernetes-pods\", code=~\"5..\", entrypoint=~\"$entrypoint\"}[5m]))",
          "legendFormat": "{{entrypoint}}",
          "datasource": {"type": "prometheus", "uid": "victoriametrics"}
        }
      ],
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["max", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "auto",
            "axisPlacement": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0.1}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "P95 Request Latency by Entrypoint",
      "description": "95th-percentile request duration computed from the histogram. Rising P95 indicates slow backends or ingress pressure.",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by(le, entrypoint) (rate(traefik_entrypoint_request_duration_seconds_bucket{job=\"kubernetes-pods\", entrypoint=~\"$entrypoint\"}[5m])))",
          "legendFormat": "{{entrypoint}}",
          "datasource": {"type": "prometheus", "uid": "victoriametrics"}
        }
      ],
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisPlacement": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Service Request Rate (selected)",
      "description": "Per-service request rate for the selected $service filter. Helps isolate which backend receives traffic.",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(service) (rate(traefik_service_requests_total{job=\"kubernetes-pods\", service=~\"$service\"}[5m]))",
          "legendFormat": "{{service}}",
          "datasource": {"type": "prometheus", "uid": "victoriametrics"}
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 15,
            "showPoints": "never",
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top Routers by Request Rate",
      "description": "Top 10 routers ordered by 5m request rate. Instant snapshot over the last 5 minutes.",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by(router) (rate(traefik_router_requests_total{job=\"kubernetes-pods\", router!=\"\"}[5m])))",
          "legendFormat": "{{router}}",
          "instant": true,
          "format": "table",
          "datasource": {"type": "prometheus", "uid": "victoriametrics"}
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {"show": false, "reducer": ["sum"], "fields": ""}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Time"},
            "properties": [{"id": "custom.hidden", "value": true}]
          },
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [
              {"id": "displayName", "value": "Requests/sec"},
              {"id": "unit", "value": "reqps"},
              {"id": "decimals", "value": 3},
              {"id": "custom.displayMode", "value": "gradient-gauge"}
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "indexByName": {"router": 0, "Value": 1},
            "renameByName": {"router": "Router"}
          }
        }
      ]
    }
  ]
}
